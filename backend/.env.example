# ─── Supabase ────────────────────────────────────────────────
# Project Settings → API. Use the BASE url (no trailing /rest/v1/).
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ─── Auth ────────────────────────────────────────────────────
# Any long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# ─── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Storage ─────────────────────────────────────────────────
# Linux/prod can use absolute paths (e.g. /var/polytechnic/uploads).
# On Windows, local relative paths work fine:
UPLOAD_DIR=./data/uploads
SHARED_DIR=./data/shared
AUDIT_LOG_DIR=./data/audit_logs
MAX_FILE_SIZE=104857600
